{
  "Kestrel": {
    "Limits": {
      "MaxRequestLineSize": 24576,
      "MaxRequestBodySize": 40000000
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug",
      "Yarp.ReverseProxy": "Debug",
      "System.Net.Http.HttpClient": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Yarp": "Debug",
        "Yarp.ReverseProxy": "Debug",
        "System.Net.Http.HttpClient": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "ReverseProxy": {
    "Routes": {
      "meta-anonymous-download": {
        "ClusterId": "meta-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/meta/{entity}/download/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "meta-api": {
        "ClusterId": "meta-cluster",
        "Match": {
          "Path": "/meta/{**catch-all}"
        }
      },
      "tenant-api": {
        "ClusterId": "tenant-cluster",
        "Match": {
          "Path": "/tenant/{**catch-all}"
        }
      },
      "generic-anonymous-download": {
        "ClusterId": "generic-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/generic/{application}/{entity}/download/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "generic-api": {
        "ClusterId": "generic-cluster",
        "Match": {
          "Path": "/generic/{**catch-all}"
        }
      },
      "reporting-api": {
        "ClusterId": "reporting-cluster",
        "Match": {
          "Path": "/document/{**catch-all}"
        }
      },
      "reporting-signon": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/document/signon/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/document"
          }
        ]
      },
      "reporting-designer": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/document/designer/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/document"
          }
        ]
      },
      "reporting-viewer": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/document/viewer/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/document"
          }
        ]
      },
      "reporting-designer-api": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/ReportDesigner/{**catch-all}"
        }
      },
      "reporting-designer-viewer-api": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/DocumentViewer/{**catch-all}"
        }
      },
      "reporting-viewer-api": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/document/api/DocumentViewer/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/document"
          }
        ]
      },
      "reporting-assets": {
        "ClusterId": "reporting-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/dx/{**catch-all}"
        }
      },
      "storage-api": {
        "ClusterId": "storage-cluster",
        "Match": {
          "Path": "/storage/{**catch-all}"
        }
      },
      "storage-anonymous-download": {
        "ClusterId": "storage-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/storage/attachment/downloadforentityandownerbyid/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "ml-anonymous-download": {
        "ClusterId": "ml-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/ml/mlmodel/download/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "ml-api": {
        "ClusterId": "ml-cluster",
        "Match": {
          "Path": "/ml/{**catch-all}"
        }
      },
      "ai-signalr": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/ai/hubs/{**catch-all}",
          "Methods": [ "GET" ],
          "Headers": [
            {
              "Name": "Connection",
              "Mode": "Contains",
              "Values": [ "Upgrade" ]
            },
            {
              "Name": "Upgrade",
              "Mode": "ExactHeader",
              "Values": [ "websocket" ]
            }
          ]
        }
      },
      "ai-chat": {
        "ClusterId": "ai-chat-cluster",
        "Match": {
          "Path": "/ai/v1/chat/completions/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/ai"
          },
          {
            "AuthorizationHeaderFromClaim": "ai_key",
            "AuthorizationScheme": "Bearer"
          },
          {
            "AuthorizationTokenToHeader": "x-mcp-ballware_meta_mcp-authorization"
          },
          {
            "AuthorizationTokenToHeader": "x-mcp-ballware_generic_mcp-authorization"
          }
        ]
      },
      "ai-api": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/ai/{entity}/{**catch-all}"
        }
      },
      "meta-mcp": {
        "ClusterId": "meta-cluster",
        "Match": {
          "Path": "/meta/mcp/{**catch-all}"
        }
      },
      "generic-mcp": {
        "ClusterId": "generic-cluster",
        "Match": {
          "Path": "/generic/mcp/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "meta-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://meta:5001"
          }
        }
      },
      "tenant-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://generic:5002"
          }
        }
      },
      "generic-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://generic:5002"
          }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://reporting:5004"
          }
        }
      },
      "storage-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://storage:5005"
          }
        }
      },
      "ml-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://ml:5005"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://llm:5006"
          }
        }
      },
      "ai-chat-cluster": {
        "Destinations": {
          "node1": {
            "Address": "http://llm:5006"
          }
        }
      }
    }
  }
}
